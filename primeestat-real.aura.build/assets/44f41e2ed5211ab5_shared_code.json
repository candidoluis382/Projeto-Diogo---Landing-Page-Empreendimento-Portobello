  <br>\n            TRUE CHARACTER\n          </h4>\n          <a data-reveal=\"\" href=\"#\" class=\"group inline-flex items-center gap-2 text-xs font-semibold tracking-[0.2em] border-b border-white pb-1 font-geist\">\n            VIEW MORE PROJECTS\n            <i data-lucide=\"arrow-up-right\" class=\"w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5\"></i>\n          </a>\n        </div>\n      </div>\n    </section>\n\n    <!-- ░░ ARCHIVE STRIP ░░ -->\n    <section id=\"archive\" class=\"relative bg-[#0a0d1f] py-20 overflow-hidden border-y border-white/5\">\n      <p data-reveal=\"\" class=\"text-xs tracking-[0.25em] text-white/40 px-6 max-w-7xl mx-auto mb-10 font-geist\">\n        [ THE ARCHIVE — 2003 → TODAY ]\n      </p>\n      <div id=\"archiveTrack\" class=\"flex gap-5 will-change-transform pl-6\" style=\"width:max-content\">\n        <div class=\"w-64 sm:w-80 aspect-[3/4] rounded-xl overflow-hidden shrink-0 ring-1 ring-white/10\">\n          <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/3ee60fc7-fc69-4bf3-99d8-9ac2bd36c178_1600w.png\" class=\"w-full h-full object-cover\" alt=\"\">\n        </div>\n        <div class=\"w-64 sm:w-80 aspect-[3/4] rounded-xl overflow-hidden shrink-0 ring-1 ring-white/10\">\n          <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/26f197e7-332b-48f0-ac33-58e8b9591b33_1600w.png\" class=\"w-full h-full object-cover\" alt=\"\">\n        </div>\n        <div class=\"w-64 sm:w-80 aspect-[3/4] rounded-xl overflow-hidden shrink-0 ring-1 ring-white/10\">\n          <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/6070cfa2-6e85-454b-91a0-f04dcf80d3d8_1600w.png\" class=\"w-full h-full object-cover\" alt=\"\">\n        </div>\n        <div class=\"w-64 sm:w-80 aspect-[3/4] rounded-xl overflow-hidden shrink-0 ring-1 ring-white/10\">\n          <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/b22c6e48-7e73-4303-b709-943feefe9ddf_1600w.png\" class=\"w-full h-full object-cover\" alt=\"\">\n        </div>\n        <div class=\"w-64 sm:w-80 aspect-[3/4] rounded-xl overflow-hidden shrink-0 ring-1 ring-white/10\">\n          <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/b53fd971-1d5d-4e6b-8983-933073de8b0b_1600w.png\" class=\"w-full h-full object-cover\" alt=\"\">\n        </div>\n        <div class=\"w-64 sm:w-80 aspect-[3/4] rounded-xl overflow-hidden shrink-0 ring-1 ring-white/10\">\n          <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/8663e7b0-c1b5-4275-b305-0051d8fce1ec_1600w.png\" class=\"w-full h-full object-cover\" alt=\"\">\n        </div>\n      </div>\n    </section>\n\n    <!-- ░░ MASKED NUMBER ░░ -->\n    <section id=\"masked\" class=\"relative bg-[#0a0d1f] py-32 overflow-hidden\">\n      <div class=\"max-w-7xl mx-auto px-6 relative\">\n        <h3 class=\"text-[34vw] md:text-[26vw] leading-none text-center bg-clip-text text-transparent select-none font-geist tracking-tighter\" style=\"background-image: url(&quot;https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/6419b50d-2b39-4cd8-8331-f25ea4e5c6f1_3840w.png&quot;); background-size: cover; background-position: center center; background-clip: text;\">\n          21\n        </h3>\n        <p data-reveal=\"\" class=\"text-center text-xs tracking-[0.3em] text-white/40 mt-4 font-geist\">\n          YEARS OF QUIET, DELIBERATE WORK\n        </p>\n        <div class=\"relative grid sm:grid-cols-2 gap-6 mt-16 max-w-3xl mx-auto\">\n          <a href=\"#\" class=\"float-card group rounded-2xl bg-white/[0.04] backdrop-blur-xl ring-1 ring-white/10 p-6 hover:-translate-y-1.5 transition-transform duration-500 will-change-transform\">\n            <div class=\"overflow-hidden rounded-xl aspect-video mb-5\">\n              <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/1424bc30-132d-4f48-aaac-82b03eeb35a2_3840w.png\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 will-change-transform\" alt=\"\">\n            </div>\n            <div class=\"flex items-center justify-between\">\n              <p class=\"text-sm font-medium font-geist\">Brennvik Apartment</p>\n              <i data-lucide=\"arrow-up-right\" class=\"w-4 h-4 text-orange-500 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5\"></i>\n            </div>\n            <p class=\"text-xs tracking-[0.2em] text-white/40 mt-1.5 font-geist\">\n              APARTMENT — 540 M²\n            </p>\n          </a>\n          <a href=\"#\" class=\"float-card group rounded-2xl bg-white/[0.04] backdrop-blur-xl ring-1 ring-white/10 p-6 sm:mt-12 hover:-translate-y-1.5 transition-transform duration-500 will-change-transform\">\n            <div class=\"overflow-hidden rounded-xl aspect-video mb-5\">\n              <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/c6b040ea-bcb4-4edb-89c4-e09134ee9a4e_3840w.png\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 will-change-transform\" alt=\"\">\n            </div>\n            <div class=\"flex items-center justify-between\">\n              <p class=\"text-sm font-medium font-geist\">Søvang Courtyard</p>\n              <i data-lucide=\"arrow-up-right\" class=\"w-4 h-4 text-orange-500 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5\"></i>\n            </div>\n            <p class=\"text-xs tracking-[0.2em] text-white/40 mt-1.5 font-geist\">\n              RESIDENCE — 720 M²\n            </p>\n          </a>\n        </div>\n      </div>\n    </section>\n\n    <!-- ░░ PROCESS TIMELINE ░░ -->\n    <section id=\"process\" class=\"relative bg